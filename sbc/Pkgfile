description=" The SBC package is a digital audio encoder and decoder used to transfer data to Bluetooth audio output devices like headphones or loudspeakers. "
name=sbc
version=2.2
release=1
packager=alexis
source=("https://www.kernel.org/pub/linux/bluetooth/sbc-2.2.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static --disable-tester &&
make
make DESTDIR=$PKG install
}
