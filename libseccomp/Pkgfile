description=" The libseccomp package provides an easy to use and platform independent interface to the Linux kernel's syscall filtering mechanism. "
name=libseccomp
version=2.6.0
release=1
packager=alexis
source=("https://github.com/seccomp/libseccomp/releases/download/v2.6.0/libseccomp-2.6.0.tar.gz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG install
}
