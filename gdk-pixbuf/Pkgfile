description="The Gdk Pixbuf package is a toolkit for image loading and pixel buffer manipulation."
name=gdk-pixbuf
version=2.44.5
release=2
packager=alexis
source=("https://download.gnome.org/sources/gdk-pixbuf/2.44/gdk-pixbuf-2.44.5.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..                \
      --prefix=/usr           \
      --buildtype=release     \
      -D png=enabled         \
      -D gif=enabled         \
      -D jpeg=enabled        \
      -D tiff=enabled        \
      -D thumbnailer=disabled \
      --wrap-mode=nofallback  \
      -Dglycin=enabled 
ninja
DESTDIR=$PKG ninja install
}
