description="The Gcr package contains libraries used for displaying certificates and accessing key stores."
name=gcr4
version=4.4.0.1
release=1
packager=alexis
source=("https://download.gnome.org/sources/gcr/4.4/gcr-4.4.0.1.tar.xz")

build() {
cd gcr-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D gtk_doc=false    \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
