description=" The Expat package contains a stream oriented C library for parsing XML. "
name=expat
version=2.7.4
release=1
packager=alexis
source=("https://github.com/libexpat/libexpat/releases/download/R_2_7_4/expat-2.7.4.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr    \
            --disable-static \
            --docdir=/usr/share/doc/expat-2.7.4

make 
make DESTDIR=$PKG install
install -v -m644 doc/*.{html,css} $PKG/usr/share/doc/expat-2.7.4
}
