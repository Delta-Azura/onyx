description=" The Bison package contains a parser generator. "
name=bison
version=3.8.2
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/bison/bison-3.8.2.tar.xz")


build() {
cd $name-$version
./configure --prefix=/usr --docdir=/usr/share/doc/bison-3.8.2
make 
make DESTDIR=$PKG install
}
