description=" The Procps-ng package contains programs for monitoring processes. "
name=procps-ng
version=4.0.6
release=1
packager=alexis
source=("https://sourceforge.net/projects/procps-ng/files/Production/procps-ng-4.0.6.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr                           \
            --docdir=/usr/share/doc/procps-ng-4.0.6 \
            --disable-static                        \
            --disable-kill                          \
            --enable-watch8bit                      \
            --with-systemd
make 
make DESTDIR=$PKG install
}
