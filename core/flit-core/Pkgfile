description=" Flit-core is the distribution-building parts of Flit (a packaging tool for simple Python modules). "
name=flit-core
version=3.12.0
release=1
packager=alexis
source=("https://pypi.org/packages/source/f/flit-core/flit_core-3.12.0.tar.gz")


build() {
ls
#cd ${name}_${version}
cd flit_core-3.12.0
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist --no-cache-dir --no-user \
    --root=$PKG --ignore-installed      \
    flit_core
}
