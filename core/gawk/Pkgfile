description=" The Gawk package contains programs for manipulating text files. "
name=gawk
version=5.3.2
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/gawk/gawk-5.3.2.tar.xz")

build() {
cd $name-$version
sed -i 's/extras//' Makefile.in
./configure --prefix=/usr
make 
rm -f $PKG/usr/bin/gawk-5.3.2
make DESTDIR=$PKG install
}
