description="The DejaGnu package contains a framework for running test suites on GNU tools."
name=dejagnu
version=1.6.3
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/dejagnu/dejagnu-1.6.3.tar.gz")

build() {
cd $name-$version
mkdir -v build
cd       build
../configure --prefix=/usr
makeinfo --html --no-split -o doc/dejagnu.html ../doc/dejagnu.texi
makeinfo --plaintext       -o doc/dejagnu.txt  ../doc/dejagnu.texi
make DESTDIR=$PKG install
install -v -dm755  $PKG/usr/share/doc/dejagnu-1.6.3
install -v -m644   doc/dejagnu.{html,txt} $PKG/usr/share/doc/dejagnu-1.6.3
}
