description=" The Binutils package contains a linker, an assembler, and other tools for handling object files. "
name=binutils
version=2.46.0
release=1
packager=alexis
source=("https://sourceware.org/pub/binutils/releases/binutils-2.46.0.tar.xz")

build() {
cd $name-$version
mkdir -v build
cd       build
../configure --prefix=/usr       \
             --sysconfdir=/etc   \
             --enable-ld=default \
             --enable-plugins    \
             --enable-shared     \
             --disable-werror    \
             --enable-64-bit-bfd \
             --enable-new-dtags  \
             --with-system-zlib  \
             --enable-default-hash-style=gnu
make tooldir=/usr
make DESTDIR=$PKG tooldir=/usr install
rm -rfv $PKG/usr/lib/lib{bfd,ctf,ctf-nobfd,gprofng,opcodes,sframe}.a \
        $PKG/usr/share/doc/gprofng/
}
