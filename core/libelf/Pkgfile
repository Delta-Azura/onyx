description=" Libelf is a library for handling ELF (Executable and Linkable Format) files. "
name=libelf
version=0.194
release=1
packager=alexis
source=("https://sourceware.org/ftp/elfutils/0.194/elfutils-0.194.tar.bz2")

build() {
cd elfutils-$version 
./configure --prefix=/usr        \
            --disable-debuginfod \
            --enable-libdebuginfod=dummy
make -C lib
make -C libelf
make DESTDIR=$PKG -C libelf install
install -vm644 config/libelf.pc $PKG/usr/lib/pkgconfig
rm $PKG/usr/lib/libelf.a
}
