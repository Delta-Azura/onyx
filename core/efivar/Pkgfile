description=" The efivar package provides tools and libraries to manipulate EFI variables. "
name=efivar
version=39
release=1
packager=alexis
source=(https://github.com/rhboot/efivar/archive/39/efivar-39.tar.gz
https://www.linuxfromscratch.org/patches/blfs/13.0/efivar-39-upstream_fixes-1.patch)


build() {
cd $name-$version
patch -Np1 -i ../efivar-39-upstream_fixes-1.patch
make ENABLE_DOCS=0
make install DESTDIR=$PKG ENABLE_DOCS=0 LIBDIR=/usr/lib
mkdir -pv $PKG/usr/share/man/man1
mkdir -pv $PKG/usr/share/man/man3
install -vm644 docs/efivar.1 $PKG/usr/share/man/man1 &&
install -vm644 docs/*.3      $PKG/usr/share/man/man3
}
