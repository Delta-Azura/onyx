description=" The efibootmgr package provides tools and libraries to manipulate EFI variables. "
name=efibootmgr
version=18
release=1
packager=alexis
source=("https://github.com/rhboot/efibootmgr/archive/18/efibootmgr-18.tar.gz")

build() {
cd $name-$version
make EFIDIR=LFS EFI_LOADER=grubx64.efi
make DESTDIR=$PKG install EFIDIR=LFS
}
