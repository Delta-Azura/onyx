description="The Libtool package contains the GNU generic library support script."
name=libtool
version=2.5.4
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/libtool/libtool-2.5.4.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr
make 
make DESTDIR=$PKG install
rm -fv $PKG/usr/lib/libltdl.a
}
