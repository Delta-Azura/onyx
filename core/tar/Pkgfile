description="The Tar package provides the ability to create tar archives as well as perform various other kinds of archive manipulation."
name=tar
version=1.35
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/tar/tar-1.35.tar.xz")

build() {
cd $name-$version 
FORCE_UNSAFE_CONFIGURE=1  \
./configure --prefix=/usr
make 
make DESTDIR=$PKG install
make DESTDIR=$PKG -C doc install-html docdir=/usr/share/doc/tar-1.35
}
