description=" Meson is an open source build system designed to be both extremely fast and as user friendly as possible. "
name=meson
version=1.10.1
release=1
packager=alexis
source=("https://github.com/mesonbuild/meson/releases/download/1.10.1/meson-1.10.1.tar.gz")


build() {
cd $name-$version 
 pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    --ignore-installed\
    meson
}
