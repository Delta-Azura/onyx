description=" The Psmisc package contains programs for displaying information about running processes. "
name=psmisc
version=23.7
release=1
packager=alexis
source=("https://sourceforge.net/projects/psmisc/files/psmisc/psmisc-23.7.tar.xz")

build() {
cd $name-$version 
./configure --prefix=/usr
make 
make DESTDIR=$PKG install
}
