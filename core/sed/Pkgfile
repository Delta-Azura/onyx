description=" The Sed package contains a stream editor. "
name=sed
version=4.9
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/sed/sed-4.9.tar.xz")


build() {
cd $name-$version
./configure --prefix=/usr
make 
make html
make DESTDIR=$PKG install
install -d -m755           $PKG/usr/share/doc/sed-4.9
install -m644 doc/sed.html $PKG/usr/share/doc/sed-4.9
}
