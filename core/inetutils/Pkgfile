description=" The Inetutils package contains programs for basic networking. "
name=inetutils
version=2.7
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/inetutils/inetutils-2.7.tar.gz")

build() {
cd $name-$version
sed -i 's/def HAVE_TERMCAP_TGETENT/ 1/' telnet/telnet.c
./configure --prefix=/usr        \
            --bindir=/usr/bin    \
            --localstatedir=/var \
            --disable-logger     \
            --disable-whois      \
            --disable-rcp        \
            --disable-rexec      \
            --disable-rlogin     \
            --disable-rsh        \
            --disable-servers
make 
make DESTDIR=$PKG install
mkdir -p $PKG/usr/sbin/
mv -v $PKG/usr/{,s}bin/ifconfig
}
