description=" The HarfBuzz package contains an OpenType text shaping engine. "
name=harfbuzz
version=12.3.2
release=2
packager=alexis
source=("https://github.com/harfbuzz/harfbuzz/releases/download/12.3.2/harfbuzz-12.3.2.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..             \
      --prefix=/usr        \
      --buildtype=release  \
      -D graphite2=enabled &&
ninja -j16
DESTDIR=$PKG ninja install
}
