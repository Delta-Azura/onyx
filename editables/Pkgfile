description=" Editables is python library for creating “editable wheels.” "
name=editables
version=0.5
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/e/editables/editables-0.5.tar.gz")


build() {
cd $name-$version

pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    editables
}
