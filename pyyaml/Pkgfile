description=" PyYAML is a Python module that implements the next generation YAML parser and emitter. "
name=pyyaml
version=6.0.3
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/P/PyYAML/pyyaml-6.0.3.tar.gz")

build() {
cd $name-$version
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    PyYAML
}
