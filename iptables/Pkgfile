description=" iptables is a userspace command line program used to configure the Linux 2.4 and later kernel packet filtering ruleset. "
name=iptables
version=1.8.12
release=1
packager=alexis
source=("https://www.netfilter.org/projects/iptables/files/iptables-1.8.12.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr      \
            --disable-nftables \
            --enable-libipq    &&
make


make DESTDIR=$PKG install
}
