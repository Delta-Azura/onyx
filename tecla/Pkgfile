description=" The Tecla package contains a keyboard layout viewer. "
name=tecla
version=49.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/tecla/49/tecla-49.0.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
