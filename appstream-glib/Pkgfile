description="The appstream-glib provides GObjects and helper methods to make it easy to read and write AppStream metadata"
name=appstream-glib
version=0.8.3
release=1
packager=alexis
source=("http://people.freedesktop.org/~hughsient/appstream-glib/releases/appstream-glib-0.8.3.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..            \
      --prefix=/usr       \
      --buildtype=release \
      -D rpm=false -D gtk-doc=false -D man=false       &&
ninja
DESTDIR=$PKG ninja install
}
