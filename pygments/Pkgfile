description=" Pygments is a general syntax highlighter written in Python, for more than 300 languages. "
name=pygments
version=2.19.2
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/P/Pygments/pygments-2.19.2.tar.gz")

build() {
cd $name-$version
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    Pygments

}
