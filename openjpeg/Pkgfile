description="OpenJPEG is an open-source implementation of the JPEG-2000 standard."
name=openjpeg
version=2.5.4
release=1
packager=alexis
source=("https://github.com/uclouvain/openjpeg/archive/v2.5.4/openjpeg-2.5.4.tar.gz")

build() {
cd $name-$version
mkdir -v build &&
cd       build &&

cmake -D CMAKE_BUILD_TYPE=Release  \
      -D CMAKE_INSTALL_PREFIX=/usr \
      -D BUILD_STATIC_LIBS=OFF ..  &&
make
make DESTDIR=$PKG install &&
mkdir -pv $PKG/usr/share/man
cp -rv ../doc/man -T $PKG/usr/share/man
}
