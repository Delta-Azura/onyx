description=" The GNOME Control Center package contains the GNOME settings manager. "
name=gnome-control-center
version=49.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/gnome-control-center/49/gnome-control-center-49.4.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
