description=" The FriBidi package is an implementation of the Unicode Bidirectional Algorithm (BIDI). "
name=fribidi
version=1.0.16
release=1
packager=alexis
source=("https://github.com/fribidi/fribidi/releases/download/v1.0.16/fribidi-1.0.16.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
