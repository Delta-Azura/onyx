description=" The HarfBuzz package contains an OpenType text shaping engine. "
name=harfbuzz
version=14.1.0
release=2
packager=alexis
source=("https://github.com/harfbuzz/harfbuzz/releases/download/${version}/harfbuzz-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..             \
      --prefix=/usr        \
      --buildtype=release  \
      -D graphite2=enabled &&
ninja -j16
DESTDIR=$PKG ninja install
}
