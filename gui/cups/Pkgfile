description=" The Common Unix Printing System (CUPS) is a print spooler and associated utilities. It is based on th and provides printing services to most PostScript and raster printers. "
name=cups
version=2.4.17
release=1
packager=alexis
source=("https://github.com/OpenPrinting/cups/releases/download/v${version}/cups-${version}-source.tar.gz")

build() {
ls
cd $name-$version
#useradd -c "Print Service User" -d /var/spool/cups -g lp -s /bin/false -u 9 lp
#groupadd -g 19 lpadmin
#usermod -a -G lpadmin alexis
sed -i 's#@CUPS_HTMLVIEW@#firefox#' desktop/cups.desktop.in
sed -i '/& ipp->prev)/s/prev/& \&\& ipp->prev->next == *attr/' cups/ipp.c
./configure --libdir=/usr/lib            \
            --with-rundir=/run/cups      \
            --with-system-groups=lpadmin \
            --with-docdir=/usr/share/cups/doc-${version} &&
make
make DESTDIR=$PKG install &&
mkdir -pv $PKG/usr/share/doc/
ln -svnf ../cups/doc-2.4.16 $PKG/usr/share/doc/cups-${version}
echo "ServerName /run/cups/cups.sock" > $PKG/etc/cups/client.conf
}
