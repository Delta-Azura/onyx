description=" PyGObject3 provides Python bindings to the GObject class from GLib. "
name=pygobject
version=3.56.2
release=1
packager=alexis
source=("https://download.gnome.org/sources/pygobject/3.56/pygobject-${version}.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
