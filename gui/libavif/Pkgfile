description=" The libavif package contains a library used for encoding and decoding AVIF files. "
name=libavif
version=1.4.1
release=1
packager=alexis
source=("https://github.com/AOMediaCodec/libavif/archive/v${version}/libavif-${version}.tar.gz")

build() {
cd $name-$version
sed 's/enable_adaptive_quantization/aq_mode/' -i src/codec_svt.c
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      -D AVIF_CODEC_AOM=SYSTEM     \
      -D AVIF_CODEC_DAV1D=SYSTEM   \
      -D AVIF_CODEC_SVT=SYSTEM     \
      -D AVIF_BUILD_GDK_PIXBUF=OFF \
      -D AVIF_LIBYUV=OFF           \
      -G Ninja .. &&
ninja
DESTDIR=$PKG ninja install
}
