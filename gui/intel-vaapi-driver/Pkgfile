description=" The intel-vaapi-driver package contains a VA API driver for Intel GPUs that are provided with Haswell CPUs and earlier. "
name=intel-vaapi-driver
version=2.4.1
release=1
packager=alexis
source=(https://github.com/intel/intel-vaapi-driver/releases/download/2.4.1/intel-vaapi-driver-2.4.1.tar.bz2)

build() {
cd $name-$version
./configure $XORG_CONFIG &&
make
make DESTDIR=$PKG install
}
