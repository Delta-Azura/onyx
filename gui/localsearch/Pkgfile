description=" The Localsearch package contains a filesystem indexer as well as a metadata extractor. "
name=localsearch
version=3.11.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/localsearch/3.11/localsearch-${version}.tar.xz")
#"https://www.linuxfromscratch.org/patches/blfs/13.0/localsearch-3.10.2-security_fixes-1.patch")

build() {
cd $name-$version
#patch -Np1 -i ../localsearch-3.10.2-security_fixes-1.patch
mkdir build &&
cd    build &&

meson setup --prefix=/usr             \
            --buildtype=release       \
            -D man=false              \
            -D functional_tests=false \
            ..                        &&
ninja
DESTDIR=$PKG ninja install
}
