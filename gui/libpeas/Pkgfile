description=" libpeas is a GObject based plugins engine, and is targeted at giving every application the chance to assume its own extensibility. "
name=libpeas
version=1.38.1
release=1
packager=alexis
source=("https://download.gnome.org/sources/libpeas/1.38/libpeas-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr          \
            --buildtype=release    \
            --wrap-mode=nofallback \
            -D python3=false       \
            ..                     &&
ninja
DESTDIR=$PKG ninja install
}
