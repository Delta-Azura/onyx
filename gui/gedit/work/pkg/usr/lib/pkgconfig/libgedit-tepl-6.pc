prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

Name: libgedit-tepl
Description: Text editor product line
Version: 6.13.0
Requires: gio-2.0 >=  2.74, gtk+-3.0 >=  3.22, libgedit-gtksourceview-300 >=  299.5, libgedit-amtk-5 >=  5.9, libgedit-gfls-1 >=  0.3
Requires.private: icu-uc, icu-i18n, gsettings-desktop-schemas >=  42, libhandy-1 >=  1.6
Libs: -L${libdir} -lgedit-tepl-6
Cflags: -I${includedir}/libgedit-tepl-6
