description="FUSE (Filesystem in Userspace) is a simple interface for userspace programs to export a virtual filesystem to the Linux kernel."
name=fuse
version=3.18.2
release=1
packager=alexis
source=("https://github.com/libfuse/libfuse/releases/download/fuse-${version}/fuse-${version}.tar.gz")

build() {
cd $name-$version
sed -i '/^udev/,$ s/^/#/' util/meson.build &&

mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install                  &&
chmod u+s $PKG/usr/bin/fusermount3 &&

cd ..                          &&
mkdir -pv $PKG/usr/share/doc
cp -Rv doc/html -T $PKG/usr/share/doc/fuse-${version} &&
install -v -m644   doc/{README.NFS,kernel.txt} \
                   $PKG/usr/share/doc/fuse-${version}
}
