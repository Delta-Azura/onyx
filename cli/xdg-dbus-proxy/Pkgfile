description="The xdg-dbus-proxy package contains a filtering proxy for D-Bus connections."
name=xdg-dbus-proxy
version=0.1.7
release=1
packager=alexis
source=("https://github.com/flatpak/xdg-dbus-proxy/releases/download/${version}/xdg-dbus-proxy-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release -D man=disabled .. &&
ninja
DESTDIR=$PKG ninja install
}
