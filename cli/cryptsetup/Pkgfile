description=" cryptsetup is used to set up transparent encryption of block devices using the kernel crypto API. "
name=cryptsetup
version=2.8.6
release=1
packager=alexis
source=("https://www.kernel.org/pub/linux/utils/cryptsetup/v2.8/cryptsetup-${version}.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr       \
            --disable-ssh-token \
            --disable-asciidoc  &&
make
make DESTDIR=$PKG install
}
