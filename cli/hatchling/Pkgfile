description=" Hatchling is an extensible, standards compliant build backend for python modules. "
name=hatchling
version=1.29.0
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/h/hatchling/hatchling-${version}.tar.gz")

build() {
cd $name-$version

pip3 wheel -w dist \
    --no-build-isolation \
     --no-deps $PWD
  pip3 install --no-deps \
    --find-links dist --ignore-installed \
    --no-cache-dir  \
    --no-user         \
    --root=$PKG       \
    hatchling

}
