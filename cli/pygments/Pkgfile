description=" Pygments is a general syntax highlighter written in Python, for more than 300 languages. "
name=pygments
version=2.20.0
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/P/Pygments/pygments-${version}.tar.gz")

build() {
cd $name-$version
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install \
    --find-links dist \
    --no-cache-dir --ignore-installed    \
    --no-user         \
    --root=$PKG       \
    Pygments

}
