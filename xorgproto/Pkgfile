description=" The xorgproto package provides the header files required to build the X Window system, and to allow other applications to build against the installed X Window system. "
name=xorgproto
version=2025.1
release=1
packager=alexis
source=("https://xorg.freedesktop.org/archive/individual/proto/xorgproto-2025.1.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=$XORG_PREFIX .. &&
ninja
DESTDIR=$PKG ninja install
mv -v $PKG/$XORG_PREFIX/share/doc/xorgproto{,-2025.1}
}
