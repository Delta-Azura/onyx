description=" This package, from the WebM project, provides the reference implementations of the VP8 Codec (used in most current HTML5 video) and of the next-generation VP9 Codec. "
name=libvpx
version=1.16.0
release=1
packager=alexis
source=("https://github.com/webmproject/libvpx/archive/v1.16.0/libvpx-1.16.0.tar.gz"
"https://www.linuxfromscratch.org/patches/blfs/13.0/libvpx-1.16.0-security_fix-1.patch")

build() {
cd $name-$version

patch -Np1 -i ../libvpx-1.16.0-security_fix-1.patch
sed -i 's/cp -p/cp/' build/make/Makefile &&

mkdir libvpx-build            &&
cd    libvpx-build            &&

../configure --prefix=/usr    \
             --enable-shared  \
             --disable-static &&
make
make DESTDIR=$PKG install
}
