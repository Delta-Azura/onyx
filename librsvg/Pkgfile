description=" The librsvg package contains a library and tools used to manipulate, convert and view Scalable Vector Graphic (SVG) images. "
name=librsvg
version=2.61.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/librsvg/2.61/librsvg-2.61.4.tar.xz")

build() {
cd $name-$version
sed -e "/OUTDIR/s|,| / 'librsvg-2.61.4', '--no-namespace-dir',|" \
    -e '/output/s|Rsvg-2.0|librsvg-2.61.4|'                      \
    -i doc/meson.build
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
