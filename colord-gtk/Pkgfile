description=" The Colord GTK package contains GTK+ bindings for Colord. "
name=colord-gtk
version=0.3.1
release=1
packager=alexis
source=("https://www.freedesktop.org/software/colord/releases/colord-gtk-0.3.1.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D gtk4=true        \
            -D vapi=true        \
            -D docs=false       \
            -D man=false        \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
