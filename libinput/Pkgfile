description=" libinput is a library that handles input devices for display servers and other applications that need to directly deal with input devices. "
name=libinput
version=1.31.0
release=1
packager=alexis
source=("https://gitlab.freedesktop.org/libinput/libinput/-/archive/1.31.0/libinput-1.31.0.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..              \
      --prefix=$XORG_PREFIX \
      --buildtype=release   \
      -D debug-gui=false    \
      -D tests=false        \
      -D libwacom=false     \
      -D udev-dir=/usr/lib/udev &&
ninja
DESTDIR=$PKG ninja install
}
