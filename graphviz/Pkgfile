description=" The Graphviz package contains graph visualization software. Graph visualization is a way of representing structural information as diagrams of abstract graphs and networks."
name=graphviz
version=14.1.2
release=1
packager=alexis
source=("https://gitlab.com/graphviz/graphviz/-/archive/14.1.2/graphviz-14.1.2.tar.bz2")

build() {
cd $name-$version
sed '/ORIGIN/d' -i lib/CMakeLists.txt
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      ..                           &&

sed -i '/GZIP/s/:.*$/=/' CMakeCache.txt &&

make
make DESTDIR=$PKG install
}
