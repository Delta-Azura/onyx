description=" The enchant package provides a generic interface into various existing spell checking libraries. "
name=enchant
version=2.8.15
release=1
packager=alexis
source=("https://github.com/rrthomas/enchant/releases/download/v2.8.15/enchant-2.8.15.tar.gz")

build() {
cd $name-$version
./configure --prefix=/usr     \
            --sysconfdir=/etc \
            --disable-static  \
            --docdir=/usr/share/doc/enchant-2.8.15 &&
make
make DESTDIR=$PKG install
}
