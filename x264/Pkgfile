description=" x264 package provides a library for encoding video streams into the H.264/MPEG-4 AVC format. "
name=x264
version=20250815 
release=1
packager=alexis
source=("https://anduin.linuxfromscratch.org/BLFS/x264/x264-20250815.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr   \
            --enable-shared \
            --disable-cli   &&
make
make DESTDIR=$PKG install
}
