description=" The libtirpc package contains libraries that support programs that use the Remote Procedure Call (RPC) API"
name=libtirpc
version=1.3.7
release=1
packager=alexis
source=("https://downloads.sourceforge.net/libtirpc/libtirpc-1.3.7.tar.bz2")

build() {
cd $name-$version
./configure --prefix=/usr     \
            --sysconfdir=/etc \
            --disable-static  \
            --disable-gssapi  &&

make
make DESTDIR=$PKG install
}
