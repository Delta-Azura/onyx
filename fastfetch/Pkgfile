description="Fastfetch is a maintained, feature-rich and performance oriented system information tool."
name=fastfetch
version=2.59.0
release=1
packager=alexis

source=("https://github.com/fastfetch-cli/fastfetch/archive/2.59.0/fastfetch-2.59.0.tar.gz")

build() { 
cd $name-$version
mkdir build
cd build
cmake -D CMAKE_INSTALL_PREFIX=/usr    \
      -D CMAKE_BUILD_TYPE=Release     \
      -D BUILD_FLASHFETCH=OFF         \
      -D PACKAGES_DISABLE_CHOCO=ON    \
      -D PACKAGES_DISABLE_MACPORTS=ON \
      -D PACKAGES_DISABLE_SCOOP=ON    \
      -D PACKAGES_DISABLE_WINGET=ON   \
      .. 
make 
make DESTDIR=$PKG install
}
