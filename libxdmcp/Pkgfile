description="The libXdmcp package contains a library implementing the X Display Manager Control Protocol."

name=libxdmcp
version=1.1.5
release=1
packager=alexis
source=("https://www.x.org/pub/individual/lib/libXdmcp-1.1.5.tar.xz")

build() {
cd libXdmcp-1.1.5
./configure $XORG_CONFIG --docdir='${datadir}'/doc/libXdmcp-1.1.5 &&
make
make DESTDIR=$PKG install
}
