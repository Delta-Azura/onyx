description=" gexiv2 is a GObject-based wrapper around the Exiv2 library. "
name=gexiv2
version=0.14.6
release=1
packager=alexis
source=("https://download.gnome.org/sources/gexiv2/0.14/gexiv2-0.14.6.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
