description=" The At-Spi2 Core package contains a comprehensive accessibility framework for the Assistive Technologies available on the GNOME platform."
name=at-spi2-core
version=2.58.3
release=1
packager=alexis 
source=("https://download.gnome.org/sources/at-spi2-core/2.58/at-spi2-core-2.58.3.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..                  \
      --prefix=/usr             \
      --buildtype=release       \
      -D gtk2_atk_adaptor=false &&
ninja
DESTDIR=$PKG ninja install
}
