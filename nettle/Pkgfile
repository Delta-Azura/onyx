description=" The Nettle package contains a low-level cryptographic library that is designed to fit easily in many contexts. "
name=nettle
version=3.10.2
release=1
packager=alexis
source=("https://ftpmirror.gnu.org/nettle/nettle-3.10.2.tar.gz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG install &&
chmod   -v   755 $PKG/usr/lib/lib{hogweed,nettle}.so &&
install -v -m755 -d $PKG/usr/share/doc/nettle-3.10.2 &&
install -v -m644 nettle.{html,pdf} $PKG/usr/share/doc/nettle-3.10.2
}
