description=" The libjxl package contains the reference implementation of the JPEG XL image format. "
name=libjxl
version=0.11.2
release=1
packager=alexis
source=("https://github.com/libjxl/libjxl/archive/v0.11.2/libjxl-0.11.2.tar.gz")


build() {
cd $name-$version
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr             \
      -D CMAKE_BUILD_TYPE=Release              \
      -D BUILD_TESTING=OFF                     \
      -D BUILD_SHARED_LIBS=ON                  \
      -D JPEGXL_ENABLE_SKCMS=OFF               \
      -D JPEGXL_ENABLE_SJPEG=OFF               \
      -D JPEGXL_ENABLE_PLUGINS=OFF             \
      -D JPEGXL_INSTALL_JARDIR=/usr/share/java \
      -G Ninja ..                              &&
ninja
DESTDIR=$PKG ninja install
}
