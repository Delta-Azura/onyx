description=" The Yelp XSL package contains XSL stylesheets that are used by the Yelp help browser to format Docbook and Mallard documents. "
name=yelp-xsl
version=49.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/yelp-xsl/49/yelp-xsl-49.0.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
