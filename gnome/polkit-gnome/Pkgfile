description="The Polkit GNOME package provides an Authentication Agent for Polkit that integrates well with the GNOME Desktop environment."
name=polkit-gnome
version=0.105
release=1
packager=alexis
source=(https://download.gnome.org/sources/polkit-gnome/0.105/polkit-gnome-0.105.tar.xz
https://www.linuxfromscratch.org/patches/blfs/13.0/polkit-gnome-0.105-consolidated_fixes-1.patch)


build() {
cd $name-$version
patch -Np1 -i ../polkit-gnome-0.105-consolidated_fixes-1.patch
./configure --prefix=/usr &&
make
make DESTDIR=$PKG install
mkdir -p $PKG/etc/xdg/autostart &&
cat > $PKG/etc/xdg/autostart/polkit-gnome-authentication-agent-1.desktop << "EOF"
[Desktop Entry]
Name=PolicyKit Authentication Agent
Comment=PolicyKit Authentication Agent
Exec=/usr/libexec/polkit-gnome-authentication-agent-1
Terminal=false
Type=Application
Categories=
NoDisplay=true
OnlyShowIn=GNOME;XFCE;Unity;
AutostartCondition=GNOME3 unless-session gnome
EOF
}
