description="Epiphany is a simple yet powerful GNOME web browser targeted at non-technical users."
name=gnome-web
_name=epiphany
version=50.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/epiphany/50/epiphany-${version}.tar.xz")

build() {
cd $_name-$version


mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
