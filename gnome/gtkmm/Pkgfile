description=" The Gtkmm package provides a C++ interface to GTK-4. "
name=gtkmm
version=4.22.0
release=1
packager=alexis
#source=(https://download.gnome.org/sources/gtkmm/${version}/gtkmm-${version}.tar.xz)
source=(https://gitlab.gnome.org/GNOME/gtkmm/-/archive/${version}/gtkmm-${version}.zip)
build() {
cd $name-$version
mkdir my_build &&
cd    my_build &&
meson setup --prefix=/usr my_build --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
