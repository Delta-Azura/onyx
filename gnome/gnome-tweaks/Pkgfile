description=" GNOME Tweaks is a simple program used to tweak advanced GNOME settings."
name=gnome-tweaks
version=49.0
release=1
packager=alexis
source=(https://download.gnome.org/sources/gnome-tweaks/49/gnome-tweaks-${version}.tar.xz)

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release &&
ninja
DESTDIR=$PKG ninja install
}
