description=" The WebKitGTK package is a port of the portable web rendering engine WebKit to the GTK-3 and GTK-4 platforms. "
name=webkitgtk4
version=2.50.5
release=1
packager=alexis
source=("https://webkitgtk.org/releases/webkitgtk-2.50.5.tar.xz")





build() {
cd webkitgtk-$version
mkdir -vp build &&
cd        build
rm -rf * .[^.]* &&
cmake -D CMAKE_BUILD_TYPE=Release         \
      -D CMAKE_INSTALL_PREFIX=/usr        \
      -D CMAKE_SKIP_INSTALL_RPATH=ON      \
      -D PORT=GTK                         \
      -D LIB_INSTALL_DIR=/usr/lib         \
      -D USE_LIBBACKTRACE=OFF             \
      -D USE_LIBHYPHEN=OFF                \
      -D ENABLE_GAMEPAD=OFF               \
      -D ENABLE_MINIBROWSER=ON            \
      -D ENABLE_DOCUMENTATION=OFF         \
      -D USE_WOFF2=OFF                    \
      -D USE_GTK4=ON                      \
      -D ENABLE_BUBBLEWRAP_SANDBOX=ON     \
      -D USE_SYSPROF_CAPTURE=NO           \
      -D ENABLE_SPEECH_SYNTHESIS=OFF      \
      -W no-dev -G Ninja ..               &&


ninja -j4
DESTDIR=$PKG ninja install
}
