description=" The libusb package contains a library used by some applications for USB device access. "
name=libusb
version=1.0.29
release=1
packager=alexis
source=("https://github.com/libusb/libusb/releases/download/v1.0.29/libusb-1.0.29.tar.bz2")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG install
}
