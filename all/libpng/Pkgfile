description="The libpng package contains libraries used by other programs for reading and writing PNG files."
name=libpng
version=1.6.57
release=1
packager=alexis

source=("https://downloads.sourceforge.net/libpng/libpng-${version}.tar.xz"
"https://downloads.sourceforge.net/sourceforge/libpng-apng/libpng-${version}-apng.patch.gz")


build() {
cd $name-$version
zcat ../libpng-${version}-apng.patch.gz | patch -p1
./configure --prefix=/usr --disable-static 
make
make DESTDIR=$PKG install
mkdir -pv $PKG/usr/share/doc/libpng-1.6.55
cp -v README libpng-manual.txt $PKG/usr/share/doc/libpng-1.6.55
}
