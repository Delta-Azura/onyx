description="The xdg-dbus-proxy package contains a filtering proxy for D-Bus connections."
name=xdg-dbus-proxy
version=0.1.6
release=1
packager=alexis
source=("https://github.com/flatpak/xdg-dbus-proxy/releases/download/0.1.6/xdg-dbus-proxy-0.1.6.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release -D man=disabled .. &&
ninja
DESTDIR=$PKG ninja install
}
