description="The GnuTLS package contains libraries and userspace tools which provide a secure layer over a reliable transport layer. "
name=gnutls
version=3.8.12
release=1
packager=alexis
source=("https://www.gnupg.org/ftp/gcrypt/gnutls/v3.8/gnutls-3.8.12.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr \
            --docdir=/usr/share/doc/gnutls-3.8.12 \
            --with-default-trust-store-pkcs11="pkcs11:" &&
make
make DESTDIR=$PKG install
}
