description=" The libxml2 package contains libraries and utilities used for parsing XML files. "
name=libxml2
version=2.15.1
release=1
packager=alexis
source=("https://download.gnome.org/sources/libxml2/2.15/libxml2-2.15.1.tar.xz")


build() {
cd $name-$version
sed -i "/'git'/,+3d" meson.build
mkdir build &&
cd    build &&

meson setup ..           \
      --prefix=/usr      \
      -D history=enabled \
      -D icu=enabled     &&
ninja
DESTDIR=$PKG ninja install
sed "s/--static/--shared/" -i $PKG/usr/bin/xml2-config
}
