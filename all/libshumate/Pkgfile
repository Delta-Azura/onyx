description=" The libshumate package contains a GTK-4 widget to display maps. "
name=libshumate
version=1.5.3
release=1
packager=alexis
source=("https://download.gnome.org/sources/libshumate/1.5/libshumate-1.5.3.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr          \
            --buildtype=release    \
            --wrap-mode=nodownload \
            -D gtk_doc=false       \
            ..                     &&
ninja
DESTDIR=$PKG ninja install
}
