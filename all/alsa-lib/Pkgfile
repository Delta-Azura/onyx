description=" The ALSA Library package contains the ALSA library used by programs (including ALSA Utilities) requiring access to the ALSA sound interface. "
name=alsa-lib
version=1.2.15.3
release=1
packager=alexis
source=("https://www.alsa-project.org/files/pub/lib/alsa-lib-1.2.15.3.tar.bz2"
"https://www.alsa-project.org/files/pub/lib/alsa-ucm-conf-1.2.15.3.tar.bz2")


build() {
cd $name-$version
./configure &&
make
make DESTDIR=$PKG install &&
cd ..
wget https://www.alsa-project.org/files/pub/lib/alsa-ucm-conf-1.2.15.3.tar.bz2
cd $name-$version
tar -C $PKG/usr/share/alsa --strip-components=1 -xf ../alsa-ucm-conf-1.2.15.3.tar.bz2
}
