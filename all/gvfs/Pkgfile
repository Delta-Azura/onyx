description=" The Gvfs package is a userspace virtual filesystem designed to work with the I/O abstractions of GLib's GIO library. "

name=gvfs
version=1.60.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/gvfs/1.60/gvfs-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup               \
      --prefix=/usr       \
      --buildtype=release \
      -D onedrive=false   \
      -D fuse=false       \
      -D gphoto2=false    \
      -D afc=false        \
      -D bluray=false     \
      -D nfs=false        \
      -D mtp=false        \
      -D smb=false        \
      -D dnssd=false      \
      -D goa=false        \
      -D google=false     .. &&
ninja
DESTDIR=$PKG ninja install
}
