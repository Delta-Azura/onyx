description="Libdrm provides a userspace library for accessing the direct rendering manager (DRM) on operating systems that support the ioctl interface. "
name=libdrm
version=2.4.131
release=1
packager=alexis
source=("https://dri.freedesktop.org/libdrm/libdrm-2.4.131.tar.xz")


build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=$XORG_PREFIX \
            --buildtype=release   \
            -D udev=true          \
            -D valgrind=disabled  \
            ..                    &&
ninja
DESTDIR=$PKG ninja install
}
