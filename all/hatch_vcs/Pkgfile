description=" Hatch_vcs is a Hatch plugin for versioning with several Version Control Systems ( VCS ). "
name=hatch_vcs
version=0.5.0
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/h/hatch-vcs/hatch_vcs-0.5.0.tar.gz")

build() {
cd $name-$version
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    hatch_vcs
}
