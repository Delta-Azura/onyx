description=" The libde265 package contains an open source H.265 video codec implementation. "
name=libde265
version=1.0.18
release=1
packager=alexis
source=("https://github.com/strukturag/libde265/releases/download/v${version}/libde265-${version}.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      .. &&
make
make DESTDIR=$PKG install
}
