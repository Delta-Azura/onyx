description="The blueprint-compiler package contains a compiler for a markup language for GTK user interfaces."
name=blueprint-compiler
version=0.20.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/blueprint-compiler/0.20/blueprint-compiler-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
