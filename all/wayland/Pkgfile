description=" Wayland is a project to define a protocol for a compositor to talk to its clients as well as a library implementation of the protocol. "
name=wayland
version=1.24.0
release=1
packager=alexis
source=("https://gitlab.freedesktop.org/wayland/wayland/-/releases/1.24.0/downloads/wayland-1.24.0.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..            \
      --prefix=/usr       \
      --buildtype=release \
      -D documentation=false &&
ninja
DESTDIR=$PKG ninja install
}
