description=" The libdaemon package is a lightweight C library that eases the writing of UNIX daemons. "
name=libdaemon
version=0.14
release=1
packager=alexis
source=("libdaemon-0.14.tar.gz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG docdir=/usr/share/doc/libdaemon-0.14 install
}
