description=" Hatchling is an extensible, standards compliant build backend for python modules. "
name=hatchling
version=1.28.0
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/h/hatchling/hatchling-1.28.0.tar.gz")

build() {
cd $name-$version

pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    hatchling
}
