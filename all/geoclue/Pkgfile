description="GeoClue is a modular geoinformation service built on top of the D-Bus messaging system."
name=geoclue
version=2.8.0
release=1
packager=alexis
source=("https://gitlab.freedesktop.org/geoclue/geoclue/-/archive/2.8.0/geoclue-2.8.0.tar.bz2")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr        \
            --buildtype=release  \
            -D gtk-doc=false     \
            -D nmea-source=false \
            ..                   &&
ninja
DESTDIR=$PKG ninja install
}
