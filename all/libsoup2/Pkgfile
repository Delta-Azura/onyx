description="The libsoup is a HTTP client/server library for GNOME."
name=libsoup2
version=2.74.3
release=1
packager=alexis
source=("https://download.gnome.org/sources/libsoup/2.74/libsoup-2.74.3.tar.xz")

build() {
cd libsoup-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D vapi=enabled     \
            -D gssapi=disabled  \
            -D sysprof=disabled \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
