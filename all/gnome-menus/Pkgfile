description="The GNOME Menus package contains an implementation of the draft Desktop Menu Specification from freedesktop.org."
name=gnome-menus
version=3.38.1
release=1
packager=alexis
source=("https://download.gnome.org/sources/gnome-menus/3.38/gnome-menus-3.38.1.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr     \
            --sysconfdir=/etc \
            --disable-static  &&
make
make DESTDIR=$PKG install
}
