description=" The libxmlb package contains a library and a tool which help create and query binary XML blobs. "
name=libxmlb
version=0.3.26
release=1
packager=alexis
source=("https://github.com/hughsie/libxmlb/releases/download/${version}/libxmlb-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release -D gtkdoc=false .. &&
ninja
DESTDIR=$PKG ninja install
}
