description="The X.Org Libinput Driver is a thin wrapper around libinput and allows for libinput to be used for input devices in X."
name=xf86-input-libinput
version=1.5.0
release=1
packager=alexis
source=("https://www.x.org/pub/individual/driver/xf86-input-libinput-1.5.0.tar.xz")

build() {
cd $name-$version
./configure $XORG_CONFIG &&
make
make DESTDIR=$PKG install
}
