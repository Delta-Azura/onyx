description="The Power-profiles-daemon package provides a program that allows modification of the system power/behavior state."
name=power-profiles-daemon
version=0.30
release=1
packager=alexis
source=("https://gitlab.freedesktop.org/upower/power-profiles-daemon/-/archive/0.30/power-profiles-daemon-0.30.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd build &&

meson setup                \
      --prefix=/usr        \
      --buildtype=release  \
      -D gtk_doc=false     \
      -D tests=false       \
      .. &&
ninja
DESTDIR=$PKG ninja install
}
