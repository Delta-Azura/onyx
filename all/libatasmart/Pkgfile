description=" The libatasmart package is a disk reporting library. It only supports a subset of the ATA S.M.A.R.T. functionality. "
name=libatasmart
version=0.19
release=1
packager=alexis
source=("libatasmart-0.19.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG docdir=/usr/share/doc/libatasmart-0.19 install
}
