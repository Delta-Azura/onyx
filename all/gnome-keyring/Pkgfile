description=" The GNOME Keyring package contains a daemon that keeps passwords and other secrets for users. "
name=gnome-keyring
version=50.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/gnome-keyring/50/gnome-keyring-${version}.tar.xz")

build() {
cd $name-$version
sed -i 's:"/desktop:"/org:' schema/*.xml &&

mkdir build-gkr &&
cd    build-gkr &&

meson setup --prefix=/usr --buildtype=release -D manpage=false .. &&
ninja
DESTDIR=$PKG ninja install
}
