description=" The Adwaita Icon Theme package contains an icon theme for GTK+ 3 and GTK 4 applications. "
name=adwaita-icon-theme
version=50.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/adwaita-icon-theme/50/adwaita-icon-theme-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr .. &&
ninja
DESTDIR=$PKG ninja install
}
