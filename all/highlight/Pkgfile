description=" Highlight is a utility that converts source code to formatted text with syntax highlighting. "
name=highlight 
version=4.18
release=1
packager=alexis
source=("http://www.andre-simon.de/zip/highlight-4.18.tar.bz2")

build() {
cd $name-$version
sed -i '/GZIP/s/^/#/' makefile
make
make DESTDIR=$PKG doc_dir=/usr/share/doc/highlight-4.18/ install
}
