description=" The Nautilus package contains the GNOME file manager. "
name=nautilus
version=49.3
release=1
packager=alexis
source=("https://download.gnome.org/sources/nautilus/49/nautilus-49.3.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release -D cloudproviders=false \
            ..                  &&

ninja
DESTDIR=$PKG ninja install
}
