description=" The Nautilus package contains the GNOME file manager. "
name=nautilus
version=50.1
release=1
packager=alexis
source=("https://download.gnome.org/sources/nautilus/50/nautilus-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release -D cloudproviders=false -D selinux=false \
            ..                  &&

ninja
DESTDIR=$PKG ninja install
}
