description=" The gspell package provides a flexible API to add spell checking to a GTK+ application. "
name=gspell
version=1.14.2
release=1
packager=alexis
source=("https://download.gnome.org/sources/gspell/1.14/gspell-1.14.2.tar.xz")

build() {
cd $name-$version
mkdir gspell-build &&
cd    gspell-build &&

meson setup --prefix=/usr --buildtype=release -D gtk_doc=false .. &&
ninja
DESTDIR=$PKG ninja install
}
