description=" The DConf package contains a low-level configuration system."
name=dconf
version=0.49.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/dconf/0.49/dconf-0.49.0.tar.xz"
"https://download.gnome.org/sources/dconf-editor/49/dconf-editor-49.0.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr            \
            --buildtype=release      \
            -D bash_completion=false -D man=false \
            ..                       &&
ninja
#ninja install
DESTDIR=$PKG ninja install
cd ..
cp -r ../dconf-editor-49.0 .
cd dconf-editor-49.0
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
