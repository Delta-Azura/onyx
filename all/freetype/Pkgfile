description=" The FreeType2 package contains a library which allows applications to properly render TrueType fonts. "
name=freetype
version=2.14.1
release=1
packager=alexis
source=("https://downloads.sourceforge.net/freetype/freetype-2.14.1.tar.xz")


build() {
cd $name-$version
sed -ri "s:.*(AUX_MODULES.*valid):\1:" modules.cfg &&

sed -r "s:.*(#.*SUBPIXEL_RENDERING) .*:\1:" \
    -i include/freetype/config/ftoption.h   &&

./configure --prefix=/usr            \
            --disable-static         \
            --enable-freetype-config \
            --with-harfbuzz=dynamic  &&
make
make DESTDIR=$PKG install
}
