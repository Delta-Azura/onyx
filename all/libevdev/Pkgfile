description=" The libevdev package contains common functions for Xorg input drivers. "
name=libevdev
version=1.13.6
release=1
packager=alexis
source=("https://www.freedesktop.org/software/libevdev/libevdev-1.13.6.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..                  \
      --prefix=$XORG_PREFIX     \
      --buildtype=release       \
      -D documentation=disabled \
      -D tests=disabled         &&
ninja
DESTDIR=$PKG ninja install
}
