description=" lxml provides Python bindings for libxslt-1.1.45 and libxml2-2.15.1. "
name=lxml
version=6.0.2
release=1
packager=alexis
source=("https://files.pythonhosted.org/packages/source/l/lxml/lxml-6.0.2.tar.gz")

build() {
cd $name-$version
pip3 wheel -w dist \
    --no-build-isolation \
    --no-deps $PWD
  pip3 install --no-index \
    --find-links dist \
    --no-cache-dir    \
    --no-user         \
    --root=$PKG       \
    lxml
}
