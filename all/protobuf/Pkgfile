description=" The Protobuf package contains utilities and libraries for using data in Google's data interchange format. "
name=protobuf
version=33.5
release=1
packager=alexis
source=("https://github.com/protocolbuffers/protobuf/releases/download/v33.5/protobuf-33.5.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr      \
      -D CMAKE_BUILD_TYPE=Release       \
      -D CMAKE_SKIP_INSTALL_RPATH=ON    \
      -D protobuf_BUILD_TESTS=OFF       \
      -D protobuf_BUILD_SHARED_LIBS=ON  \
      -G Ninja ..                       &&
ninja
DESTDIR=$PKG ninja install
}
