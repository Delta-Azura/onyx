description=" The libgudev package contains GObject bindings for libudev. "
name=libgudev
version=238
release=1
packager=alexis
source=("https://download.gnome.org/sources/libgudev/238/libgudev-238.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
