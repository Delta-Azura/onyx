description=" The libgpg-error package contains a library that defines common error values for all GnuPG components. "
name=libgpg-error
version=1.60
release=1
packager=alexis
source=("https://www.gnupg.org/ftp/gcrypt/libgpg-error/libgpg-error-${version}.tar.bz2")

build() {
cd $name-$version
./configure --prefix=/usr --sysconfdir=/etc &&
make
make DESTDIR=$PKG install
install -v -m644 -D README $PKG/usr/share/doc/libgpg-error-${version}/README
}
