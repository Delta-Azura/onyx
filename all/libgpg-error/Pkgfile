description=" The libgpg-error package contains a library that defines common error values for all GnuPG components. "
name=libgpg-error
version=1.59
release=1
packager=alexis
source=("https://www.gnupg.org/ftp/gcrypt/libgpg-error/libgpg-error-1.59.tar.bz2")

build() {
cd $name-$version
./configure --prefix=/usr --sysconfdir=/etc &&
make
make DESTDIR=$PKG install
install -v -m644 -D README $PKG/usr/share/doc/libgpg-error-1.59/README
}
