description="The libsoup3 is a HTTP client/server library for GNOME."
name=libsoup
version=3.6.6
release=1
packager=alexis
source=("https://download.gnome.org/sources/libsoup/3.6/libsoup-3.6.6.tar.xz"
"https://www.linuxfromscratch.org/patches/blfs/13.0/libsoup-3.6.6-upstream_fixes-1.patch")

build() {
cd $name-$version
patch -Np1 -i ../libsoup-3.6.6-upstream_fixes-1.patch
sed 's/apiversion/soup_version/' -i docs/reference/meson.build
mkdir build &&
cd    build &&

meson setup --prefix=/usr          \
            --buildtype=release    \
            --wrap-mode=nofallback \
            ..                     &&
ninja
DESTDIR=$PKG ninja install
}
