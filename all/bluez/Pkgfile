description=" The BlueZ package contains the Bluetooth protocol stack for Linux. "
name=bluez
version=5.86
release=1
packager=alexis
source=("https://www.kernel.org/pub/linux/bluetooth/bluez-5.86.tar.xz")

build() {
cd $name-$version
sed -i '4967,4968d' src/adapter.c
./configure --prefix=/usr         \
            --sysconfdir=/etc     \
            --localstatedir=/var  \
            --enable-library      &&
make
make DESTDIR=$PKG install
ln -svf ../libexec/bluetooth/bluetoothd $PKG/usr/sbin
install -v -dm555 $PKG/etc/bluetooth &&
install -v -m644 src/main.conf $PKG/etc/bluetooth/main.conf
}
