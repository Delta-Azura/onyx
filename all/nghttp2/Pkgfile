description=" nghttp2 is an implementation of HTTP/2 and its header compression algorithm, HPACK. "
name=nghttp2
version=1.68.0
release=1
packager=alexis
source=("https://github.com/nghttp2/nghttp2/releases/download/v1.68.0/nghttp2-1.68.0.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr     \
            --disable-static  \
            --enable-lib-only \
            --docdir=/usr/share/doc/nghttp2-1.68.0 &&
make
make DESTDIR=$PKG install
}
