description=" The sdl2-compat package provides a compatibility layer for packages that require SDL2, utilizing SDL3 as the backend. "
name=sdl2-compat
version=2.32.64
release=1
packager=alexis
source=("https://www.libsdl.org/release/sdl2-compat-2.32.64.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D SDL2COMPAT_STATIC=OFF       \
      -D SDL2COMPAT_TESTS=OFF        \
      -W no-dev -G Ninja ..          &&

ninja


DESTDIR=$PKG ninja install &&
rm -vf $PKG/usr/lib/libSDL2_test.a
}
