description=" The highway package contains a C++ library that provides portable SIMD/vector intrinsics. "
name=highway
version=1.3.0
release=1
packager=alexis
source=("https://github.com/google/highway/archive/1.3.0/highway-1.3.0.tar.gz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      -D BUILD_TESTING=OFF         \
      -D BUILD_SHARED_LIBS=ON      \
      -G Ninja ..                  &&
ninja
DESTDIR=$PKG ninja install
}
