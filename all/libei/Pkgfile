description=" The libei package contains a set of libraries for handling emulated inputs. It is primarily aimed at the Wayland stack. "
name=libei
version=1.5.0
release=1
packager=alexis
source=("https://gitlab.freedesktop.org/libinput/libei/-/archive/1.5.0/libei-1.5.0.tar.bz2")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release -D tests=disabled &&
ninja
DESTDIR=$PKG ninja install
}
