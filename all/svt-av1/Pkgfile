description=" The SVT-AV1 package contains an AV1 encoder. "
name=svt-av1
version=4.0.1
release=1
packager=alexis
source=("https://gitlab.com/AOMediaCodec/SVT-AV1/-/archive/v4.0.1/SVT-AV1-v4.0.1.tar.gz")

build() {
cd SVT-AV1-v4.0.1
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D BUILD_SHARED_LIBS=ON        \
      -W no-dev -G Ninja .. &&

ninja
DESTDIR=$PKG ninja install
}
