description=" The GNOME Terminal package contains the terminal emulator for GNOME Desktop. "
name=gnome-terminal
version=3.58.1
release=1
packager=alexis
source=("https://gitlab.gnome.org/GNOME/gnome-terminal/-/archive/3.58.1/gnome-terminal-3.58.1.tar.gz")

build() {
cd $name-$version
sed -i -r 's:"(/system):"/org/gnome\1:g' src/external.gschema.xml
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release -D docs=false .. &&
ninja
DESTDIR=$PKG ninja install
}
