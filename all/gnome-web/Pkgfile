description="Epiphany is a simple yet powerful GNOME web browser targeted at non-technical users."
name=gnome-web
version=49.2
release=1
packager=alexis
source=("https://download.gnome.org/sources/epiphany/49/epiphany-49.2.tar.xz")

build() {
cd epiphany-$version


mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
