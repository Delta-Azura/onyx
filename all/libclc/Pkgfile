description="The libclc package contains an implementation of the library requirements of the OpenCL C programming language, as specified by the OpenCL 1.1 Specification. "
name=libclc
version=22.1.4
release=1
packager=alexis
#source=(https://github.com/llvm/llvm-project/releases/download/llvmorg-${version}/libclc-${version}.src.tar.xz)
#source=(https://github.com/llvm/llvm-project/releases/download/llvmorg-${version}/)
source=(https://github.com/llvm/llvm-project/releases/download/llvmorg-${version}/llvm-project-${version}.src.tar.xz)

build() {
cd llvm-project-${version}.src/libclc
mkdir build &&
cd    build &&

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      -G Ninja ..                  &&
ninja
DESTDIR=$PKG ninja install
}
