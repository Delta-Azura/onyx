description="The libogg package contains the Ogg file structure."
name=libogg
version=1.3.6
release=1
packager=alexis
source=("https://downloads.xiph.org/releases/ogg/libogg-1.3.6.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr    \
            --disable-static \
            --docdir=/usr/share/doc/libogg-1.3.6 &&
make
make DESTDIR=$PKG install
}
