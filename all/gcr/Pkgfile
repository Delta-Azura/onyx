description="The Gcr package contains libraries used for displaying certificates and accessing key stores."
name=gcr
version=3.41.2
release=1
packager=alexis
source=("https://download.gnome.org/sources/gcr/3.41/gcr-3.41.2.tar.xz")

build() {
cd $name-$version
sed '/ssh.add/d; /ssh.agent/d' -i meson.build
sed -i 's:"/desktop:"/org:' schema/*.xml &&

mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D gtk_doc=false    \
            -D ssh_agent=false  \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
