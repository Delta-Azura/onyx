description=" The GNOME Shell is the core user interface of the GNOME Desktop environment. "
name=gnome-shell
version=49.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/gnome-shell/49/gnome-shell-49.4.tar.xz")


build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D tests=false      \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
