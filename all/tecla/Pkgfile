description=" The Tecla package contains a keyboard layout viewer. "
name=tecla
version=50.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/tecla/50/tecla-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
