description=" xdg-desktop-portal-gnome is a backend for xdg-desktop-portal which uses GTK and various pieces of GNOME infrastructure. "
name=xdg-desktop-portal-gnome
version=50.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/xdg-desktop-portal-gnome/50/xdg-desktop-portal-gnome-${version}.tar.xz")

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
