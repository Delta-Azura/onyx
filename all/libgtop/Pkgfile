description=" The libgtop package contains a library for accessing system performance data. "
name=libgtop
version=2.41.3
release=1
packager=alexis
source=("https://download.gnome.org/sources/libgtop/2.41/libgtop-2.41.3.tar.xz")

build() {
cd $name-$version
./configure --prefix=/usr --disable-static &&
make
make DESTDIR=$PKG install
}
