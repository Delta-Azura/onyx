description=" The At-Spi2 Core package contains a comprehensive accessibility framework for the Assistive Technologies available on the GNOME platform."
name=at-spi2-core
version=2.60.1
release=1
packager=alexis 
source=(https://gitlab.gnome.org/GNOME/at-spi2-core/-/archive/${version}/at-spi2-core-${version}.tar.gz)

build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup ..                  \
      --prefix=/usr             \
      --buildtype=release       \
      -D gtk2_atk_adaptor=false &&
ninja
DESTDIR=$PKG ninja install
}
