description=" The libgweather package is a library used to access weather information from online services for numerous locations. "
name=libgweather
version=4.4.4
release=1
packager=alexis
source=("https://download.gnome.org/sources/libgweather/4.4/libgweather-4.4.4.tar.xz"
"https://www.linuxfromscratch.org/patches/blfs/13.0/libgweather-4.4.4-upstream_fix-1.patch")

build() {
cd $name-$version
patch -Np1 -i ../libgweather-4.4.4-upstream_fix-1.patch
mkdir build &&
cd    build &&

meson setup --prefix=/usr       \
            --buildtype=release \
            -D gtk_doc=false    \
            ..                  &&
ninja
DESTDIR=$PKG ninja install
}
