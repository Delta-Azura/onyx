description="The libadwaita package provides additional GTK4 UI widgets for use in developing user interfaces."
name=libadwaita
version=1.9.0
release=1
packager=alexis
source=("https://download.gnome.org/sources/libadwaita/1.9/libadwaita-${version}.tar.xz")


build() {
cd $name-$version
mkdir build &&
cd    build &&

meson setup --prefix=/usr --buildtype=release .. &&
ninja
DESTDIR=$PKG ninja install
}
