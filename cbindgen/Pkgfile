description=" Cbindgen can be used to generate C bindings for Rust code. "
name=cbindgen
version=0.29.2
release=1
packager=alexis
source=("https://github.com/mozilla/cbindgen/archive/v0.29.2/cbindgen-0.29.2.tar.gz")

build() {
cd $name-$version
cargo build --release
mkdir -p $PKG/usr/bin
install -Dm755 target/release/cbindgen $PKG/usr/bin/
}
