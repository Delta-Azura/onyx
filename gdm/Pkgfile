description=" GDM is a system service that is responsible for providing graphical logins and managing local and remote displays. "
name=gdm
version=49.2
release=1
packager=alexis
source=("https://download.gnome.org/sources/gdm/49/gdm-49.2.tar.xz")

build() {
cd $name-$version
#groupadd -g 21 gdm &&
#useradd -c "GDM Daemon Owner" -d /var/lib/gdm -u 21 \
#        -g gdm -s /bin/false gdm &&
#passwd -ql gdm
mkdir build &&
cd    build &&

meson setup ..             \
      --prefix=/usr        \
      --buildtype=release  \
      -D gdm-xsession=true \
      -D run-dir=/run/gdm  &&
ninja
DESTDIR=$PKG ninja install
}
